{
  "obsidian_vault": "",
  "endnote_library": "",
  "endnote_libraries": [],
  "exclude_dirs": [
    ".obsidian",
    ".smart-connections",
    "textgenerator"
  ],
  "runtime": {
    "python_home": ""
  },
  "index": {
    "db_path": "",
    "auto_refresh": false,
    "obsidian_chunk_chars": 1400,
    "endnote_chunk_chars": 1800,
    "stale_seconds": 900,
    "obsidian_stale_note_threshold": 3,
    "obsidian_stale_size_bytes": 32768,
    "obsidian_stale_mtime_grace_seconds": 604800,
    "endnote_stale_db_size_bytes": 65536,
    "endnote_stale_pdf_count_threshold": 5,
    "endnote_stale_pdf_mtime_grace_seconds": 604800,
    "stale_warning_after_days": 7
  },
  "models": {
    "embedding": "BAAI/bge-m3",
    "reranker": "BAAI/bge-reranker-v2-m3",
    "backend": "torch",
    "default_device": "cpu",
    "deep_device": "cuda_if_available"
  },
  "service": {
    "host": "127.0.0.1",
    "port": 53744,
    "preload_models": false,
    "idle_shutdown_seconds": 300,
    "deep_worker_idle_seconds": 60,
    "max_parallel_deep_requests": 1,
    "startup_timeout_seconds": 240,
    "request_timeout_seconds": 600
  },
  "retrieval": {
    "profile_default": "fast",
    "top_k_recall": 40,
    "top_k_rerank": 20,
    "top_k_evidence": 6
  }
